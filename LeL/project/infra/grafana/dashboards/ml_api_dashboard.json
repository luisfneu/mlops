{
  "id": null,
  "uid": "mlops-lel-api",
  "title": "MLOps LeL — Wine Classifier API",
  "tags": ["mlops", "fastapi", "ml"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Predições / s",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(ml_predictions_total[1m]))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Total Predições",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [{ "expr": "sum(ml_predictions_total)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Latência p95 (s)",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Confiança média",
      "id": 4,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(ml_prediction_confidence_sum[5m])) / sum(rate(ml_prediction_confidence_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Predições por classe (rate 1m)",
      "id": 5,
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (predicted_class) (rate(ml_predictions_total[1m]))",
          "legendFormat": "classe {{predicted_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latência (p50/p95/p99)",
      "id": 6,
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests/s por status",
      "id": 7,
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Distribuição de confiança (avg/p10/p90)",
      "id": 8,
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.1, sum(rate(ml_prediction_confidence_bucket[5m])) by (le))",
          "legendFormat": "p10",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.5, sum(rate(ml_prediction_confidence_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(ml_prediction_confidence_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "C"
        }
      ]
    }
  ]
}
